---
const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Playground', href: '/playground/' },
      { label: 'VS Code Extension', href: '/vscode/' },
      { label: 'CLI', href: '/docs/' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Docs', href: '/docs/' },
      { label: 'Getting Started', href: '/docs/getting_started/' },
      { label: 'API Reference', href: '/docs/api_reference/' },
    ],
  },
  {
    title: 'Community',
    links: [
      { label: 'GitHub', href: 'https://github.com/ajitpratap0/GoSQLX' },
      { label: 'Discussions', href: 'https://github.com/ajitpratap0/discussions' },
      { label: 'Contributing', href: 'https://github.com/ajitpratap0/blob/main/CONTRIBUTING.md' },
    ],
  },
];
---

<footer class="bg-surface border-t border-elevated relative">
  <!-- Gradient accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-orange-500 via-blue-500 to-green-500"></div>
  <div class="container mx-auto px-4 py-12">
    <a href="/" class="block mb-8">
      <picture>
        <source srcset="/images/logo.webp" type="image/webp">
        <img src="/images/logo.png" alt="GoSQLX" class="h-8" width="58" height="32" />
      </picture>
    </a>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-slate-200 uppercase tracking-wider mb-4">
            {col.title}
          </h3>
          <ul class="space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-400 hover:text-slate-200 transition-colors text-sm py-1 block"
                  {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-10 pt-6 border-t border-elevated text-center text-sm text-slate-400">
      &copy; 2026 GoSQLX Authors. Apache-2.0 License.
    </div>
  </div>
</footer>
