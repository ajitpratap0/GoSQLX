---
const badges = [
  {
    src: "https://img.shields.io/github/stars/ajitpratap0/GoSQLX?style=flat-square&color=yellow",
    alt: "GitHub Stars",
    href: "https://github.com/ajitpratap0/GoSQLX",
  },
  {
    src: "https://img.shields.io/github/actions/workflow/status/ajitpratap0/GoSQLX/ci.yml?style=flat-square&label=tests",
    alt: "Tests",
    href: "https://github.com/ajitpratap0/GoSQLX/actions",
  },
  {
    src: "https://goreportcard.com/badge/github.com/ajitpratap0/GoSQLX?style=flat-square",
    alt: "Go Report Card",
    href: "https://goreportcard.com/report/github.com/ajitpratap0/GoSQLX",
  },
  {
    src: "https://img.shields.io/badge/godoc-reference-blue?style=flat-square",
    alt: "GoDoc",
    href: "https://pkg.go.dev/github.com/ajitpratap0/GoSQLX",
  },
];
---

<section class="py-16 border-t border-slate-800">
  <div class="container mx-auto px-4">
    <div class="flex flex-wrap items-center justify-center gap-4">
      {badges.map((badge) => (
        <a href={badge.href} target="_blank" rel="noopener noreferrer">
          <img src={badge.src} alt={badge.alt} class="h-5" loading="lazy" />
        </a>
      ))}
    </div>
  </div>
</section>
