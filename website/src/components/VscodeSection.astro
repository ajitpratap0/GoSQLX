---
---

<section class="py-20">
  <div class="container mx-auto px-4">
    <div class="max-w-5xl mx-auto bg-surface rounded-2xl border border-slate-700 overflow-hidden">
      <div class="flex flex-col md:flex-row items-center">
        <!-- Left: description -->
        <div class="md:w-1/2 p-8 md:p-12">
          <h2 class="text-2xl font-bold text-white mb-3">IDE Integration</h2>
          <p class="text-slate-400 mb-6 leading-relaxed">
            Real-time SQL validation, formatting, and linting in VS Code.
            Get instant feedback as you write queries with full multi-dialect support.
          </p>
          <a
            href="https://marketplace.visualstudio.com/items?itemName=ajitpratap0.gosqlx"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white px-5 py-2.5 rounded-lg font-medium text-sm transition-colors"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.583 2.248L9.26 9.307l-4.025-3.054L2 7.702v8.591l3.235 1.449 4.025-3.054 8.323 7.06L22 19.51V4.484l-4.417-2.236zM5.235 13.908V10.09l2.236 1.908-2.236 1.91zm12.348 2.726L9.92 11.998l7.663-4.637v9.273z"/>
            </svg>
            Install Extension
          </a>
        </div>

        <!-- Right: mockup placeholder -->
        <div class="md:w-1/2 p-8 md:p-12">
          <div class="bg-code rounded-xl border border-slate-700 p-6">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
              <span class="text-xs text-slate-500 ml-2">query.sql - GoSQLX</span>
            </div>
            <div class="space-y-2 font-mono text-sm">
              <div class="text-slate-500">
                <span class="text-blue-400">SELECT</span> <span class="text-slate-300">u.name, u.email</span>
              </div>
              <div class="text-slate-500">
                <span class="text-blue-400">FROM</span> <span class="text-slate-300">users u</span>
              </div>
              <div class="text-slate-500">
                <span class="text-blue-400">WHERE</span> <span class="text-slate-300">u.active =</span> <span class="text-green-400">true</span>
              </div>
              <div class="mt-3 bg-green-500/10 border border-green-500/20 rounded px-3 py-1.5">
                <span class="text-green-400 text-xs">&#10003; Valid SQL - 0 warnings, 0 errors</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
