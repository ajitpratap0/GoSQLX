---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} - GoSQLX`}>
  <main class="max-w-4xl mx-auto px-4 py-16">
    <a
      href="/GoSQLX/blog/"
      class="inline-flex items-center gap-1 text-sm text-blue-400 hover:text-blue-300 mb-8"
    >
      &larr; Back to Release Notes
    </a>

    <div class="mb-6">
      <div class="flex items-center gap-3 mb-3">
        <span class="inline-block px-2.5 py-0.5 text-xs font-semibold rounded-full bg-blue-500/20 text-blue-400 border border-blue-500/30">
          v{post.data.version}
        </span>
        {post.data.date && (
          <span class="text-sm text-gray-500">{post.data.date}</span>
        )}
      </div>
      <h1 class="text-3xl font-bold text-white">{post.data.title}</h1>
    </div>

    <article class="prose prose-invert max-w-none">
      <Content />
    </article>
  </main>
</BaseLayout>
